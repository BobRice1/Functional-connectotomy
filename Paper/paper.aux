\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces  \textbf  {Comparison of fitted parameter landscapes for the control and glioma cohorts.} (a) Optimal coupling strength $K^*$ as a function of excitability $\lambda $ for the control and glioma PLI targets. The glioma curve lies consistently above the control curve, indicating that the glioma target requires higher fitted coupling. (b) Control-cohort fit landscape over the $K$--$\lambda $ grid, with the dashed line showing the fitted constant-$\kappa $ relation. (c) Glioma-cohort fit landscape over the same grid, showing a higher fitted normalised coupling than control. Together, the panels indicate a shift toward stronger effective interregional coupling in the glioma model fit. }}{7}{figure.3}\protected@file@percent }
\newlabel{fig:network_glioma}{{3}{7}{\textbf {Comparison of fitted parameter landscapes for the control and glioma cohorts.} (a) Optimal coupling strength $K^*$ as a function of excitability $\lambda $ for the control and glioma PLI targets. The glioma curve lies consistently above the control curve, indicating that the glioma target requires higher fitted coupling. (b) Control-cohort fit landscape over the $K$--$\lambda $ grid, with the dashed line showing the fitted constant-$\kappa $ relation. (c) Glioma-cohort fit landscape over the same grid, showing a higher fitted normalised coupling than control. Together, the panels indicate a shift toward stronger effective interregional coupling in the glioma model fit}{figure.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.7}Structural connectivity perturbation}{7}{section*.21}\protected@file@percent }
\citation{Alexandersen2025}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces  \textbf  {Functional connectotomy analysis.} (a) Distribution of optimal glioma fitted coupling $K^*$ before and after connectotomy for each tumour-region set, showing how masking tumour-related regions changes the coupling required to fit the glioma PLI target. (b) Histogram of connectotomy-induced coupling shifts, expressed relative to the corresponding control shift, showing that the effect varies across tumour-region groupings and initial conditions. (c) Empirical structural connectivity matrix with tumour-related regions highlighted, showing where the masked regions lie within the anatomical network. (d) Summary of the mean connectotomy effect relative to control for each tumour-region set, with error bars showing variability across initial conditions. Together, the panels show that tumour-region masking generally alters fitted coupling in the glioma model, but that the size of the control-relative effect depends on the region set being removed. }}{8}{figure.4}\protected@file@percent }
\newlabel{fig:network_connectotomy}{{4}{8}{\textbf {Functional connectotomy analysis.} (a) Distribution of optimal glioma fitted coupling $K^*$ before and after connectotomy for each tumour-region set, showing how masking tumour-related regions changes the coupling required to fit the glioma PLI target. (b) Histogram of connectotomy-induced coupling shifts, expressed relative to the corresponding control shift, showing that the effect varies across tumour-region groupings and initial conditions. (c) Empirical structural connectivity matrix with tumour-related regions highlighted, showing where the masked regions lie within the anatomical network. (d) Summary of the mean connectotomy effect relative to control for each tumour-region set, with error bars showing variability across initial conditions. Together, the panels show that tumour-region masking generally alters fitted coupling in the glioma model, but that the size of the control-relative effect depends on the region set being removed}{figure.4}{}}
