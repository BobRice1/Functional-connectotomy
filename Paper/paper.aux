\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  \textbf  {Empirical-scale network fitting.} (a) Empirical structural connectivity matrix used to define the 78-node coupled Hopf network. (b) Simulated PLI matrix at the best-fitting control-cohort parameter combination, shown here for \(K = 60.00\) and \(\lambda = 13.06\). (c) Empirical control-cohort PLI matrix. (d) Empirical glioma-cohort PLI matrix. The simulated matrix reproduces broad block-structured organisation also visible in the empirical data, supporting the use of the coupled Hopf network as a coarse-grained model of large-scale functional connectivity. }}{5}{figure.1}\protected@file@percent }
\newlabel{fig:network_matrices}{{1}{5}{\textbf {Empirical-scale network fitting.} (a) Empirical structural connectivity matrix used to define the 78-node coupled Hopf network. (b) Simulated PLI matrix at the best-fitting control-cohort parameter combination, shown here for \(K = 60.00\) and \(\lambda = 13.06\). (c) Empirical control-cohort PLI matrix. (d) Empirical glioma-cohort PLI matrix. The simulated matrix reproduces broad block-structured organisation also visible in the empirical data, supporting the use of the coupled Hopf network as a coarse-grained model of large-scale functional connectivity}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces  \textbf  {Log--log parameter search for the empirical control network.} (a) Mean model fit across initial conditions, computed as the Pearson correlation between simulated and empirical control matrices over the $K$--$\lambda $ grid. (b--c) Fit landscapes from two representative initial conditions, showing that the high-fit region is reproducible across runs. The dashed diagonal line indicates constant normalised coupling, $\kappa = K/\sqrt  {\lambda }$, illustrating that the best-fitting region is organised primarily by the balance between global coupling strength and local excitability rather than by either parameter independently. }}{5}{figure.2}\protected@file@percent }
\newlabel{fig:network_scaling}{{2}{5}{\textbf {Log--log parameter search for the empirical control network.} (a) Mean model fit across initial conditions, computed as the Pearson correlation between simulated and empirical control matrices over the $K$--$\lambda $ grid. (b--c) Fit landscapes from two representative initial conditions, showing that the high-fit region is reproducible across runs. The dashed diagonal line indicates constant normalised coupling, $\kappa = K/\sqrt {\lambda }$, illustrating that the best-fitting region is organised primarily by the balance between global coupling strength and local excitability rather than by either parameter independently}{figure.2}{}}
