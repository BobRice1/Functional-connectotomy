\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces  Per-region structural sensitivity of the control fit over the mild damage range ($0 \leq d \leq 0.5$). Bars show the slope of $K^{*}_{\mathrm  {control}}$ versus damage for each perturbed region, ranked from largest to smallest, with driver regions highlighted. Contrary to the original hypothesis, driver regions do not separate clearly from the non-driver set by exhibiting systematically steeper damage responses. }}{12}{figure.10}\protected@file@percent }
\newlabel{fig:scpert_sensitivity}{{10}{12}{Per-region structural sensitivity of the control fit over the mild damage range ($0 \leq d \leq 0.5$). Bars show the slope of $K^{*}_{\mathrm {control}}$ versus damage for each perturbed region, ranked from largest to smallest, with driver regions highlighted. Contrary to the original hypothesis, driver regions do not separate clearly from the non-driver set by exhibiting systematically steeper damage responses}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces  Change in the control-glioma coupling gap under structural damage. Plotted is the mean difference $\langle K^{*}_{\mathrm  {control}} \rangle - \langle K^{*}_{\mathrm  {glioma}} \rangle $ across driver and non-driver groups as a function of damage fraction. More negative values indicate that the control fit lies further below the glioma fit. Damage increases this separation rather than producing convergence. }}{12}{figure.11}\protected@file@percent }
\newlabel{fig:scpert_convergence}{{11}{12}{Change in the control-glioma coupling gap under structural damage. Plotted is the mean difference $\langle K^{*}_{\mathrm {control}} \rangle - \langle K^{*}_{\mathrm {glioma}} \rangle $ across driver and non-driver groups as a function of damage fraction. More negative values indicate that the control fit lies further below the glioma fit. Damage increases this separation rather than producing convergence}{figure.11}{}}
