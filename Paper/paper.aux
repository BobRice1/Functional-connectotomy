\citation{Honey2009,Cabral2012}
\citation{Cabral2011}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces  Relationship between virtual-lesioning importance and structural-perturbation sensitivity. Each point represents one of the 15 regions tested in the structural perturbation analysis. The x-axis shows functional importance from the virtual-lesioning atlas, quantified as $|\Delta K_{\mathrm  {control}}|$. The y-axis shows structural sensitivity, quantified as the slope of fitted $K^{*}_{\mathrm  {control}}$ over the mild damage range $0 \leq d \leq 0.5$. Virtual-lesioning importance did not significantly predict structural-perturbation sensitivity, indicating that functional fit-sensitivity and anatomical damage sensitivity capture distinct properties of the model. }}{11}{figure.8}\protected@file@percent }
\newlabel{fig:partA_partB_comparison}{{8}{11}{Relationship between virtual-lesioning importance and structural-perturbation sensitivity. Each point represents one of the 15 regions tested in the structural perturbation analysis. The x-axis shows functional importance from the virtual-lesioning atlas, quantified as $|\Delta K_{\mathrm {control}}|$. The y-axis shows structural sensitivity, quantified as the slope of fitted $K^{*}_{\mathrm {control}}$ over the mild damage range $0 \leq d \leq 0.5$. Virtual-lesioning importance did not significantly predict structural-perturbation sensitivity, indicating that functional fit-sensitivity and anatomical damage sensitivity capture distinct properties of the model}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces  Dose-response of fitted coupling under structural damage. Solid lines show $K^{*}$ values obtained when fitting to the control PLI target, and dashed lines show fits to the glioma target, for the 10 virtual-lesioning analysis driver regions and 5 non-driver comparison regions. Although fitted coupling changes with increasing damage, the trajectories do not show a consistent driver-specific amplification and the control curves do not move toward the glioma-like regime. }}{11}{figure.9}\protected@file@percent }
\newlabel{fig:scpert_dose_response}{{9}{11}{Dose-response of fitted coupling under structural damage. Solid lines show $K^{*}$ values obtained when fitting to the control PLI target, and dashed lines show fits to the glioma target, for the 10 virtual-lesioning analysis driver regions and 5 non-driver comparison regions. Although fitted coupling changes with increasing damage, the trajectories do not show a consistent driver-specific amplification and the control curves do not move toward the glioma-like regime}{figure.9}{}}
