\citation{BullmoreSporns2009}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces  \textbf  {Region-wise virtual-lesioning effects on fitted coupling.} Top: glioma-cohort lesioning effect, $\Delta K_i = K^*_{\mathrm  {lesion},i} - K^*_{\mathrm  {full}}$, for all 78 AAL regions ranked by effect size. Bottom: control-cohort lesioning effects shown in the same regional order. Bar colours indicate large-scale network affiliation, and grey vertical lines show variability across initial conditions. Negative values indicate that masking a region reduces the fitted optimal coupling, suggesting that the region contributes to the coupling required by the model fit. The heterogenous ranking shows that fitted-coupling sensitivity is concentrated in specific regions rather than distributed uniformly across the brain. }}{9}{figure.5}\protected@file@percent }
\newlabel{fig:ranked_dk}{{5}{9}{\textbf {Region-wise virtual-lesioning effects on fitted coupling.} Top: glioma-cohort lesioning effect, $\Delta K_i = K^*_{\mathrm {lesion},i} - K^*_{\mathrm {full}}$, for all 78 AAL regions ranked by effect size. Bottom: control-cohort lesioning effects shown in the same regional order. Bar colours indicate large-scale network affiliation, and grey vertical lines show variability across initial conditions. Negative values indicate that masking a region reduces the fitted optimal coupling, suggesting that the region contributes to the coupling required by the model fit. The heterogenous ranking shows that fitted-coupling sensitivity is concentrated in specific regions rather than distributed uniformly across the brain}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces  \textbf  {Glioma-specific virtual-lesioning effect for each AAL region.} Bars show the differential lesioning score, $\Delta K^{\mathrm  {glioma}}_i - \Delta K^{\mathrm  {control}}_i$, ranked across regions. Positive values indicate regions whose masking reduces fitted coupling more strongly in the glioma fit than in the control fit. Red region labels mark regions belonging to the tumour-region set used in the original study. The ranking highlights a subset of regions with stronger glioma-specific influence on the simulated--empirical PLI fitting objective. }}{9}{figure.6}\protected@file@percent }
\newlabel{fig:differential_atlas}{{6}{9}{\textbf {Glioma-specific virtual-lesioning effect for each AAL region.} Bars show the differential lesioning score, $\Delta K^{\mathrm {glioma}}_i - \Delta K^{\mathrm {control}}_i$, ranked across regions. Positive values indicate regions whose masking reduces fitted coupling more strongly in the glioma fit than in the control fit. Red region labels mark regions belonging to the tumour-region set used in the original study. The ranking highlights a subset of regions with stronger glioma-specific influence on the simulated--empirical PLI fitting objective}{figure.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Region-wise virtual lesioning}{9}{section*.24}\protected@file@percent }
\citation{Honey2009,Cabral2012}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces  \textbf  {Relationship between structural hubness and virtual-lesioning effect size.} (a--c) Control-cohort associations between lesioning effect size and structural degree, weighted strength, and eigenvector centrality, respectively. (d--f) Corresponding glioma-cohort associations for the same three structural measures. Each point represents one AAL region, coloured by large-scale network affiliation. Degree counts the number of structural connections of a region, weighted strength sums the weights of those connections, and eigenvector centrality measures how strongly a region is connected to other highly connected regions. Degree and weighted strength show no clear association with lesioning effect size, whereas eigenvector centrality is positively associated with lesioning effects in both cohorts, with a stronger relationship in glioma. }}{10}{figure.7}\protected@file@percent }
\newlabel{fig:hubness_vs_dk}{{7}{10}{\textbf {Relationship between structural hubness and virtual-lesioning effect size.} (a--c) Control-cohort associations between lesioning effect size and structural degree, weighted strength, and eigenvector centrality, respectively. (d--f) Corresponding glioma-cohort associations for the same three structural measures. Each point represents one AAL region, coloured by large-scale network affiliation. Degree counts the number of structural connections of a region, weighted strength sums the weights of those connections, and eigenvector centrality measures how strongly a region is connected to other highly connected regions. Degree and weighted strength show no clear association with lesioning effect size, whereas eigenvector centrality is positively associated with lesioning effects in both cohorts, with a stronger relationship in glioma}{figure.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Structural perturbation}{10}{section*.25}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Overall interpretation}{10}{section*.26}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces  \textbf  {Dose-response of fitted coupling under structural damage.} Fitted coupling $K^*$ is shown as a function of damage level $d$ for each perturbed region. Solid lines show fits to the control PLI target, and dashed lines show fits to the glioma PLI target. Regions are grouped as virtual-lesioning drivers and non-driver comparisons. Although fitted coupling changes with increasing damage, the trajectories do not show a consistent driver-specific amplification or convergence of the control fit toward the glioma-like regime. }}{11}{figure.8}\protected@file@percent }
\newlabel{fig:scpert_dose_response}{{8}{11}{\textbf {Dose-response of fitted coupling under structural damage.} Fitted coupling $K^*$ is shown as a function of damage level $d$ for each perturbed region. Solid lines show fits to the control PLI target, and dashed lines show fits to the glioma PLI target. Regions are grouped as virtual-lesioning drivers and non-driver comparisons. Although fitted coupling changes with increasing damage, the trajectories do not show a consistent driver-specific amplification or convergence of the control fit toward the glioma-like regime}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces  \textbf  {Per-region structural-perturbation sensitivity over the mild damage range.} Bars show the slope of fitted control coupling, $K^*_{\mathrm  {control}}$, against damage level over $0 \leq d \leq 0.5$ for each perturbed region. Regions are ranked by sensitivity, with virtual-lesioning drivers distinguished from non-driver comparisons. Driver regions do not show consistently steeper damage responses than non-drivers, indicating that functional driver status does not translate into stronger anatomical perturbation sensitivity. }}{11}{figure.9}\protected@file@percent }
\newlabel{fig:scpert_sensitivity}{{9}{11}{\textbf {Per-region structural-perturbation sensitivity over the mild damage range.} Bars show the slope of fitted control coupling, $K^*_{\mathrm {control}}$, against damage level over $0 \leq d \leq 0.5$ for each perturbed region. Regions are ranked by sensitivity, with virtual-lesioning drivers distinguished from non-driver comparisons. Driver regions do not show consistently steeper damage responses than non-drivers, indicating that functional driver status does not translate into stronger anatomical perturbation sensitivity}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces  \textbf  {Relationship between virtual-lesioning importance and structural-perturbation sensitivity.} Each point represents one perturbed AAL region, coloured by driver status. The x-axis shows functional importance from the virtual-lesioning atlas, quantified as $|\Delta K^{\mathrm  {control}}|$. The y-axis shows structural sensitivity, quantified as the slope of fitted $K^*_{\mathrm  {control}}$ over the mild damage range $0 \leq d \leq 0.5$. The lack of a clear association indicates that regions strongly influencing the PLI fitting objective are not necessarily the regions whose structural weakening most strongly alters fitted coupling. }}{11}{figure.10}\protected@file@percent }
\newlabel{fig:partA_partB_comparison}{{10}{11}{\textbf {Relationship between virtual-lesioning importance and structural-perturbation sensitivity.} Each point represents one perturbed AAL region, coloured by driver status. The x-axis shows functional importance from the virtual-lesioning atlas, quantified as $|\Delta K^{\mathrm {control}}|$. The y-axis shows structural sensitivity, quantified as the slope of fitted $K^*_{\mathrm {control}}$ over the mild damage range $0 \leq d \leq 0.5$. The lack of a clear association indicates that regions strongly influencing the PLI fitting objective are not necessarily the regions whose structural weakening most strongly alters fitted coupling}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces  \textbf  {Change in the control--glioma coupling gap under structural damage.} Mean fitted-coupling difference, $\langle K^*_{\mathrm  {control}}\rangle - \langle K^*_{\mathrm  {glioma}}\rangle $, is shown across damage levels for driver and non-driver regions. More negative values indicate that the control fit lies further below the glioma fit. Structural damage increases this separation rather than moving the control fit toward the glioma-like higher-coupling regime. }}{11}{figure.11}\protected@file@percent }
\newlabel{fig:scpert_convergence}{{11}{11}{\textbf {Change in the control--glioma coupling gap under structural damage.} Mean fitted-coupling difference, $\langle K^*_{\mathrm {control}}\rangle - \langle K^*_{\mathrm {glioma}}\rangle $, is shown across damage levels for driver and non-driver regions. More negative values indicate that the control fit lies further below the glioma fit. Structural damage increases this separation rather than moving the control fit toward the glioma-like higher-coupling regime}{figure.11}{}}
